{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
